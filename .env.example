# Environment Variables

# Solana RPC (use free tier or paid service)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jupiter API (no key needed for v6)
# https://quote-api.jup.ag/v6

# 1inch API Key (get from https://portal.1inch.io)
NEXT_PUBLIC_INCH_API_KEY=your_1inch_api_key_here

# Birdeye API Key (get from https://www.birdeye.so/)
NEXT_PUBLIC_BIRDEYE_KEY=your_birdeye_api_key_here

# DexScreener API (no key needed)
# https://api.dexscreener.com
